SITE_URL="http://localhost:3000"

# AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Login Creds
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public docs/pitch-deck availability controls.
# Visibility values: "on", "off", or "schedule".
DOCS_PUBLIC_VISIBILITY="schedule"
DOCS_PUBLIC_START_AT="2026-05-10T00:00:00+06:00"
DOCS_PUBLIC_END_AT="2027-05-10T23:59:59+06:00"
DOCS_PUBLIC_DURATION_HOURS=
DOCS_TEAM_JSON='{"name":"Narrative Guard Team","members":[{"fullName":"Team Member","role":"Role","email":"member@example.com","imageUrl":""}]}'

# Used for wiping all data in development
ENABLE_WIPE_ALL_DATA="false"
WIPE_ALL_DATA_TOKEN=

# Generate below using `bunx @convex-dev/auth` command.
# Check using `bunx convex env list` command and look for `JWT_PRIVATE_KEY` and `JWKS` keys.
JWT_PRIVATE_KEY=
JWKS=
